<Window x:Class="IHM_BASE.INSCRIPTION"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="INSCRIPTION" Height="450" Width="800">
    <Grid>
        
        <!--SECTION LABEL Create compte-->
        <Label x:Name="Label_User" Content="Utilisateur:" HorizontalAlignment="Left" Margin="96,134,0,0" VerticalAlignment="Top" Height="48" Width="123" FontSize="20"/>
        <Label x:Name="Label_Password" Content="Mots de passe:" HorizontalAlignment="Left" Margin="72,217,0,0" VerticalAlignment="Top" Height="48" Width="147" FontSize="20"/>
        <Label x:Name="Label_Confirm" Content="Confirmation Mdp :" HorizontalAlignment="Left" Margin="68,288,0,0" VerticalAlignment="Top" Height="44" Width="179" FontSize="20"/>
        <Label x:Name="Label_Titre" Content="Créer un compte: " HorizontalAlignment="Center" Margin="0,39,0,0" VerticalAlignment="Top" Height="79" Width="380" FontSize="48"/>

        <!--SECTION BOX-->
        <TextBox x:Name="Tbx_User" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top" Width="320" Height="48" FontSize="26" Margin="260,134,0,0"/>
        <PasswordBox Height="48" Margin="260,217,220,0" x:Name="Tbx_Password" VerticalAlignment="Top" Background="White" FontSize="26"/>
        <PasswordBox Height="48" Margin="260,284,220,0" x:Name="Tbx_Confirm" VerticalAlignment="Top" Background="White" FontSize="26"/>

        <Button x:Name="Button_Create" Content="Créer un compte:" HorizontalAlignment="Center" Margin="0,355,0,0" VerticalAlignment="Top" Height="50" Width="173" FontSize="20" Click="Button_Create_Click"/>

    </Grid>
</Window>
