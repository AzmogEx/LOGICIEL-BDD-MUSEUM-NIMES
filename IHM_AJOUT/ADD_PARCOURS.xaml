<Window x:Class="IHM_BASE.ADD_PARCOURS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="Parcours" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Orientation="Vertical" Margin="26,8,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,20,0,20">
                <Label Content="Nom du parcours (32)" HorizontalContentAlignment="Right" Width="150"  Margin="0,0,10,0"/>
                <TextBox x:Name="TB_NomParcours" Width="200" MaxLength="32"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <TextBlock Text="Description du parcours (256)" TextAlignment="Center" TextWrapping="Wrap" Width="150" Margin="0,0,10,0"/>
                <TextBox x:Name="TB_DescParcours" Width="200" Height="200" TextWrapping="Wrap" MaxLength="256"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Width="360">
                <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="TB_NombreSelect" Text="Nombre d'espèces sélectionnées : " Width="150" TextWrapping="Wrap" Margin="0,10,10,0" />
                </StackPanel>
                <ListBox Name="LB_Animaux" HorizontalAlignment="Right" VerticalAlignment="Top" Width="200" Height="150" SelectionMode="Multiple" SelectionChanged="LB_Animaux_SelectionChanged"/>
            </StackPanel>
            <ListBox Name="LB_Animaux_Select" HorizontalAlignment="Right" VerticalAlignment="Top"
         Width="200" Height="150" SelectionMode="Multiple" IsEnabled="False" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BTN_Import" Click="ImportImage_Click" Content="Importer une image" Width="130" Height="38" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Border BorderBrush="Gray" BorderThickness="1" Width="200" Height="200" AllowDrop="True">
                        <Image x:Name="ImagePreview" Stretch="Uniform" />
                    </Border>
                    <Label Content="Credits :" Width="129" HorizontalContentAlignment="Center"/>
                    <TextBox x:Name="TB_Credits" MaxLength="16" Width="120"/>
                    <Button x:Name="BTN_DeleteImg" IsEnabled="False" Width="38" Height="38" HorizontalAlignment="Center" Margin="0,10,0,0" Click="BTN_DeleteImg_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE74D;" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <Button HorizontalAlignment="Right" x:Name="BTN_AJOUT" VerticalAlignment="Bottom" Content="Créer un parcours" Padding="10" Margin="20" Click="BTN_AJOUT_Click"/>
        <Button x:Name="BTN_Return" Content="Retour" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10,10,170,20" Height="41" Width="80" Click="BTN_Retour_Click"/>
        <CheckBox x:Name="Check_AfficheParcours" Content="Afficher le parcours (Cocher pour afficher)" HorizontalAlignment="Left" Margin="734,478,0,0" VerticalAlignment="Top" IsChecked="True" Height="22" Width="246"/>
    </Grid>
</Window>