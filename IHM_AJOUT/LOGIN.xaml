<Window x:Class="IHM_BASE.LOGIN"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="LOGIN" Height="800" Width="1200">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="400" Width="650">
            <Label x:Name="Label_Titre" Content="Identifiants de connexion:" HorizontalAlignment="Center" Height="79" Width="555" FontSize="48"/>
            <StackPanel Orientation="Horizontal">
                <Label x:Name="Label_User" Content="Utilisateur:" HorizontalAlignment="Center" Margin="30,0,0,0" VerticalAlignment="Center" Height="48" Width="123" FontSize="20"/>
                <TextBox x:Name="Tbx_User" HorizontalAlignment="Center" Margin="20" TextWrapping="Wrap" VerticalAlignment="Center" Width="320" Height="48" FontSize="26"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label x:Name="Label_Password" Content="Mots de passe:" HorizontalAlignment="Center" Margin="10,0,0,0" VerticalAlignment="Center" Height="48" Width="147" FontSize="20"/>
                <PasswordBox Height="48" Width="320" x:Name="Tbx_Password" Margin="20" VerticalAlignment="Center" Background="White" FontSize="26"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="Button_Annuler" Margin="20" Content="Annuler" HorizontalAlignment="Center" VerticalAlignment="Top" Height="50" Width="130" FontSize="20" Click="Button_Annuler_Click"/>
                <Button x:Name="Button_Connect" Margin="20" Content="Se connecter" HorizontalAlignment="Center" VerticalAlignment="Top" Height="50" Width="130" FontSize="20" Click="Button_Connect_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
