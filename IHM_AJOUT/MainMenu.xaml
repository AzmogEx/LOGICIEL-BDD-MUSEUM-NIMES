<Window x:Class="IHM_BASE.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="Menu" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Label Content="Administration:" FontSize="50" VerticalAlignment="Top" HorizontalAlignment="Center"/>
        <!--SECTION BUTTON CRUD-->
        <Border BorderThickness="3" BorderBrush="Black" Margin="205,202,575,187">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="Gestion des especes:" FontSize="20" FontWeight="Bold"/>
                <Button x:Name="BTN_ADD" HorizontalAlignment="Left" FontSize="12" Content="Ajouter" Padding="10" Click="BTN_ADD_Click" Width="80"/>
                <Button x:Name="BTN_SUPPR" HorizontalAlignment="Left" FontSize="12" Content="Supprimer" Padding="10" Width="80" Click="BTN_SUPPR_Click"/>
                <Button x:Name="BTN_EDIT" HorizontalAlignment="Left" FontSize="12" Content="Modifier espèce" Padding="10" Click="BTN_EDIT_Click" Width="120" Margin="0,0,0,20"  />
            </StackPanel>
        </Border>

        <Border BorderBrush="Black" BorderThickness="3" Margin="743,235,6,169">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                <Label Content="Gestion des parcours:" FontSize="20" FontWeight="Bold" Width="241"/>
                <Button x:Name="BTN_PARCOURS" HorizontalAlignment="Right" FontSize="12" Content=" Ajouter Parcours" Padding="10" Width="120" Click="BTN_PARCOURS_Click"/>
                <Button x:Name="BTN_EDIT_PARCOURS" HorizontalAlignment="Right" FontSize="12" Content="Modifier parcours" Padding="10" Click="BTN_EDIT_PARCOURS_Click" Width="120" />
            </StackPanel>
        </Border>

        <!--SECTION LISTBOX-->
        <ListBox Width="200" HorizontalAlignment="Left" x:Name="LB_Especes" SelectionChanged="LB_Especes_SelectionChanged" Margin="0,53,0,0"/>
        <TextBox VerticalAlignment="Top" HorizontalAlignment="Left" Width="200" Height="50" x:Name="SearchBox_Espece" TextChanged="SearchBox_Espece_TextChanged"/>

        <!--SECTION BUTTONS-->

        <Border BorderBrush="Black" BorderThickness="3" Margin="477,382,327,0">
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                <Label Content="Accès client:" FontSize="20" FontWeight="Bold"/>
                <Button x:Name="BTN_CLIENT" HorizontalAlignment="Right" FontSize="12" Content="Page Client" Padding="10" Margin="20" Width="auto" Click="BTN_COUCOU_CLICK" />
                <Button x:Name="BTN_CREATE_USER" HorizontalAlignment="Right" FontSize="12" Content="Créer un compte" Padding="10" Margin="10" Width="auto" Click="BTN_CREATE_USER_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
