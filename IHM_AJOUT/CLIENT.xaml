<Window xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"  x:Class="IHM_BASE.CLIENT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        FontFamily="Segoe UI Black"
        Title="Musée des Animaux" Height="1080" Width="1920">
    <!--PENSER A RAJOUTER LE RETRAIT DES FONCTIONS ALT F4 ETC... SI DESSUS-->
    <Grid>
        <Border x:Name="Border_Especes" Visibility="Hidden" d:Visibility="Hidden">

            <Grid x:Name="Grid_Especes_Parcours" Visibility="Hidden" d:Visibility="Hidden">
                <Image Margin="1529,0,0,647" Source="RESSOURCES/haut-droite.png" Stretch="Fill"/>
                <Button x:Name="Btn_Admin2" Content="Admin" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="Btn_Admin_Click" Height="61" Width="88">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Image Margin="0,647,1537,0" Source="RESSOURCES/bas-gauche.png" Stretch="Fill"/>
                <Image Margin="0,0,1587,647" Source="RESSOURCES/haut-gauche.png" Stretch="Fill"/>
                <Image Margin="1595,743,0,0" Source="RESSOURCES/bas-droite.png" Stretch="Fill"/>
                <Label x:Name="Label_Nom_Parcours" d:Content="Nom parcours" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="70" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White" FontFamily="Segoe UI Black" Margin="0,24,0,0"/>
                <Label x:Name="Label_Description_Parcours" d:Content="Description parcours" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White" FontFamily="Segoe UI Black" Margin="0,129,0,0"/>
                <!-- Affichage dynamique des animaux avec Images et Informations -->
                <ItemsControl x:Name="EspecesList" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="Border_Cards" Margin="10" Padding="10" Background="{Binding CardColor}" CornerRadius="10">
                                <StackPanel>
                                    <!-- Image de l'espèce -->
                                    <Image Source="{Binding ImgPath}" Stretch="Fill" Width="260" Height="155" Margin="10,10,10,0">
                                        <Image.Clip>
                                            <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,258,153" />
                                        </Image.Clip>
                                    </Image>
                                    <Label x:Name="Label_Credits" Content="{Binding Credits}" FontFamily="Arial" Foreground="{Binding TextColor}" FontStyle="Italic" HorizontalContentAlignment="Right" HorizontalAlignment="Right"/>
                                    <!-- Nom Commun de l'espèce -->
                                    <TextBlock Text="{Binding NomCommun}" Width="220" FontWeight="Bold" TextAlignment="Center" Foreground="{Binding TextColor}" FontSize="24" Margin="5" />

                                    <!-- Nom Scientifique -->
                                    <TextBlock Text="{Binding NomScientifique}" FontStyle="Italic" TextAlignment="Center" Foreground="{Binding TextColor}" TextWrapping="Wrap" FontSize="16" Margin="0,10,0,10" FontFamily="Arial" />

                                    <!-- Bouton pour accéder a l'espece -->
                                    <Button Background="Transparent" x:Name="Btn_Open_Espece" Width="150" Content="Voir l'espece" Command="{Binding OpenEspeceCommand}" Click="Btn_Open_Espece_Click" Foreground="{Binding TextColor}" FontSize="18" Height="50" BorderThickness="1" BorderBrush="Black">
                                        <Button.Template>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Background="Red" x:Name="Button_Close2" Height="60" Width="142" VerticalAlignment="Top" HorizontalAlignment="Right" Content="Retour" Command="{Binding OpenParcoursCommand}" Click="Button_Close2_Click" BorderThickness="1" FontSize="30" BorderBrush="Red" Margin="0,20,20,0">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        <!--============================================================================-->

        <!--Grille Parcours -->
        <Border x:Name="Border_Parcours" Visibility="Visible" d:Visibility="Hidden">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF4A90E2" Offset="0"/>
                    <GradientStop Color="#FF174387" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid x:Name="Grid_Parcours" Visibility="Visible" d:Visibility="Hidden">
                <Image Margin="0,647,1537,0" Source="RESSOURCES/bas-gauche.png" Stretch="Fill"/>
                <Button x:Name="Btn_Admin" Content="Admin" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="Btn_Admin_Click" Height="61" Width="88">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Image Margin="1529,0,0,647" Source="RESSOURCES/haut-droite.png" Stretch="Fill"/>
                <Image Margin="0,0,1587,647" Source="RESSOURCES/haut-gauche.png" Stretch="Fill"/>
                <Image Margin="1595,743,0,0" Source="RESSOURCES/bas-droite.png" Stretch="Fill"/>
                <Label HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="20" FontSize="10" Foreground="#1d4a90" Content="Crédits: Adam Marzuk / Mathis Mourot-Faraut" />
                <Image HorizontalAlignment="Center" VerticalAlignment="Bottom" Source="RESSOURCES/Logo_Museum_MDN_Noir.png" Height="120"  Width="370" Margin="0,0,0,13"/>
                <Label Height="100" Width="1200" VerticalAlignment="Top" Margin="0,15,0,0" Foreground="White" Content="Découvrez les espèces du Muséum" FontSize="64" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                <Grid HorizontalAlignment="Center">
                    <ItemsControl x:Name="ParcoursList" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" BorderThickness="2" Margin="10" BorderBrush="White">
                                    <Border Padding="10" Width="400" Background="#5784BA" CornerRadius="10">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Image Source="{Binding imgPathParcours}" Stretch="Fill" Width="350" Height="225" Margin="0,10,0,0">
                                                <Image.Clip>
                                                    <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,348,223" />
                                                </Image.Clip>
                                            </Image>
                                            <Label Content="{Binding credits}" HorizontalContentAlignment="Right" FontFamily="Arial" FontStyle="Italic" HorizontalAlignment="Right" Height="30"/>
                                            <TextBlock Text="{Binding nomParcours}" Width="250" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="28" Margin="0,0,0,10" />
                                            <Button Background="#5784BA" Width="170" Command="{Binding OpenParcoursCommand}" Click="Btn_Open_Parcours_Click" Foreground="White" FontSize="18" Height="50" BorderThickness="1" BorderBrush="Black">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Content" Value="Voir le parcours"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding idParcours}" Value="0">
                                                                <Setter Property="Content" Value="Voir la carte"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Border>
        <!--============================================================================-->
        <Border x:Name="Border_Recherche_Animal" Visibility="Hidden" d:Visibility="Visible">
            <!--Grille de recherche d'animal-->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF4A90E2" Offset="0"/>
                    <GradientStop Color="#FF174387" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid x:Name="Grid_Recherche" Visibility="Hidden" d:Visibility="VIsible">
                <Button Background="Red" x:Name="Button_Back_Parcours" Height="60" Width="142" VerticalAlignment="Top" HorizontalAlignment="Right" Content="Retour" Command="{Binding OpenParcoursCommand}" Click="Button_Close2_Click" BorderThickness="1" FontSize="30" BorderBrush="Red" Margin="0,10,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Grille principale -->
                <Grid Margin="10" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1253*" />
                        <!-- Carte -->
                        <ColumnDefinition Width="647*" />
                        <!-- Résultats -->
                    </Grid.ColumnDefinitions>



                    <!-- Carte du monde -->
                    <Border Grid.Column="0" Background="Transparent" Margin="0,12,272,-12" Grid.ColumnSpan="2">
                        <Grid Margin="0,-56,0,0">
                            <!-- Carte du monde -->
                            <Image Source="RESSOURCES/monde.png" Stretch="Fill" HorizontalAlignment="Left" Width="1598" />
                            <!-- Zones cliquables -->
                            <Canvas>
                                <!-- AMERIQUE DU NORD -->
                                <Button Canvas.Left="10" Canvas.Top="40" Width="660" Height="601" Background="Transparent" BorderBrush="Transparent" 
                    Click="Zone_Click_Amerique_Nord" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0"/>

                                <!-- AMERIQUE DU SUD -->
                                <Button Canvas.Left="388" Canvas.Top="618" Width="220" Height="403" Background="Transparent" BorderBrush="Transparent"
                                    Click="Zone_Click_Amerique_Sud" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0">
                                </Button>

                                <!-- AFRIQUE -->
                                <Button Canvas.Left="686" Canvas.Top="479" Width="240" Height="443" Background="Transparent" BorderBrush="Transparent"
                                Click="Zone_Click_Afrique" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0">
                                </Button>
                                <Button Canvas.Left="931" Canvas.Top="637" Width="139" Height="265" Background="Transparent" BorderBrush="Transparent"
                                Click="Zone_Click_Afrique" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0">
                                </Button>

                                <!-- Europe -->
                                <Button Canvas.Left="675" Width="256" Height="387" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Europe" HorizontalAlignment="Left" VerticalAlignment="Center" Content="@" Canvas.Top="92" Opacity="0"/>
                                <Button Canvas.Left="936" Width="98" Height="336" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Europe" HorizontalAlignment="Center" VerticalAlignment="Top" Content="@" Canvas.Top="67" Opacity="0"/>

                                <!-- Asie -->
                                <Button Canvas.Left="1039" Canvas.Top="67" Width="589" Height="616" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Asie" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0" FontFamily="Segoe UI Black">
                                </Button>
                                <Button Canvas.Left="931" Canvas.Top="408" Width="103" Height="200" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Asie" HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0" FontFamily="Segoe UI Black">
                                </Button>

                                <!-- Oceanie -->
                                <Button Canvas.Left="1274" Canvas.Top="688" Width="312" Height="264" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Oceanie" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0">
                                </Button>

                                <!-- Antartique -->
                                <Button Canvas.Left="470" Canvas.Top="1013" Width="972" Height="100" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Antartique" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0">
                                </Button>
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel HorizontalAlignment="Right" Height="1000" Width="230" Margin="0,94,0,-14">
                    <Border CornerRadius="10" BorderThickness="2" Height="1000" Background="#5784BA" Margin="-10" BorderBrush="White">
                        <ListBox x:Name="Lstbx_Animaux" MouseDoubleClick="Lstbx_Animaux_MouseDoubleClick" HorizontalContentAlignment="Center" VerticalAlignment="Top" HorizontalAlignment="Right" Width="230" Height="930" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
                            <ListBox.Resources>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="70" Width="200" Background="Transparent" HorizontalAlignment="Center" CornerRadius="10" Margin="2">
                                        <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                            <TextBlock Text="{Binding nomCommun}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16" Foreground="White" FontFamily="Segoe UI Black"/>
                                            <TextBlock Text="{Binding nomScientifique}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" FontStyle="Italic" Foreground="White" FontFamily="Arial"/>
                                        </StackPanel>
                                         </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
                <Label x:Name="Label_Region" HorizontalAlignment="Left" d:Content="Region" HorizontalContentAlignment="Center" Margin="1682,1030,0,0" FontSize="20" VerticalAlignment="Top" Width="245"/>
            </Grid>

        </Border>
        <!--============================================================================-->
        <Border x:Name="Border_Info" Visibility="Visible" d:Visibility="Hidden">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF009EE4" Offset="0"/>
                    <GradientStop Color="#FF005C97" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <!--Grille d'affichage de l'animal recherché-->
            <Grid x:Name="Grid_Info" Visibility="Hidden" d:Visibility="Hidden">

                <Image Margin="1529,0,0,647" Source="RESSOURCES/haut-droite.png" Stretch="Fill"/>

                <Image Margin="-71,382,1199,-50" Source="RESSOURCES/rond-blanc.png" Stretch="Fill"/>

                <Image Margin="0,800,1657,0" Source="RESSOURCES/bas-gauche.png" Stretch="Fill"/>

                <Image Margin="0,0,1587,647" Source="RESSOURCES/haut-gauche.png" Stretch="Fill"/>

                <Image Margin="726,330,730,269" Source="RESSOURCES/rond.png" Stretch="Fill"/>
                <Label x:Name="Label_Credits" Content="Credits 1" HorizontalContentAlignment="Center" Margin="822,816,822,226" FontStyle="Italic" FontFamily="Arial"/>

                <Label x:Name="Label_Credits2" Content="Credits 2" VerticalContentAlignment="Bottom" HorizontalContentAlignment="Center" Margin="1494,27,230,1028" FontStyle="Italic" FontFamily="Arial"/>

                <Label x:Name="Label_Credits3" Content="Credits 3" HorizontalContentAlignment="Center" Margin="1248,1043,432,10" FontStyle="Italic" FontFamily="Arial"/>

                <Button Background="Red" x:Name="Button_Close" Visibility="Collapsed" Margin="0,20,20,0" Height="60" Width="142" VerticalAlignment="Top" HorizontalAlignment="Right" Content="Retour" Command="{Binding OpenParcoursCommand}" Click="Button_Close_Click" BorderThickness="1" FontSize="30" BorderBrush="Red">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Background="Red" x:Name="Button_Back_Carte" Visibility="Collapsed" Margin="0,20,20,0" Height="60" Width="142" VerticalAlignment="Top" HorizontalAlignment="Right" Content="Retour" Command="{Binding OpenParcoursCommand}" BorderThickness="1" FontSize="30" BorderBrush="Red" Click="Button_Back_Carte_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Margin="300,150,0,0" Width="400" Height="200" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0">
                        <Border Margin="0,0,0,8" CornerRadius="10" Background="#dd8e0b" Width="350" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label x:Name="Label_Famille" Content="Embranchement" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Black"/>
                        </Border>
                        <Border Margin="0,0,0,8" CornerRadius="10" Background="#d3dd0b" Width="295" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label x:Name="Label_Ordre" Content="Classe" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Black"/>
                        </Border>
                        <Border Margin="0,0,0,8" CornerRadius="10" Background="#94dd0b" Width="240" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label x:Name="Label_Classe" Content="Ordre" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Black"/>
                        </Border>
                        <Border Margin="0,0,0,8" CornerRadius="10" Background="#32dd0b " Width="185" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Label x:Name="Label_Embranchement" Content="Famille" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Black"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="70,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="Tbx_Description_Global" TextAlignment="Left" Margin="25,0,20,0" HorizontalAlignment="Left" TextWrapping="Wrap" Height="440" Width="225" Text="TextBlock" VerticalAlignment="Bottom"  FontSize="15" Foreground="#FF2C2E87"/>
                        <TextBlock x:Name="Tbx_Description_Global1" TextAlignment="Left" Margin="0,0,0,0" HorizontalAlignment="Left" TextWrapping="Wrap" Height="440" Width="225" Text="TextBlock" VerticalAlignment="Bottom"  FontSize="15" Foreground="#FF2C2E87"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="Text_UICN" TextAlignment="Center" HorizontalAlignment="Right" TextWrapping="Wrap" Text="TextBlock" Height="160" Width="300" VerticalAlignment="Top" Foreground="#FFCE1619" Margin="160,10,0,0" FontSize="15"/>

                        <Border Background="White" Margin="300,0,0,0" BorderThickness="3" BorderBrush="Black" CornerRadius="20" Height="126">
                            <StackPanel Orientation="Vertical" Margin="15,0,15,0">
                                <TextBlock x:Name="Text_Critere_Menace" TextAlignment="Center" Margin="0,10,0,20" TextWrapping="Wrap" Text="TextBlock" Height="58" Width="200" FontSize="20" FontWeight="Bold" Foreground="#FF2C2E87"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Txt_UICN_Black" Background="BLack" Text="" Width="20" Height="10" FontSize="15" />
                                    <TextBlock x:Name="Txt_UICN_Red" Background="Red" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                    <TextBlock x:Name="Txt_UICN_Orange" Background="Orange" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                    <TextBlock x:Name="Txt_UICN_Yellow" Background="#feed00" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                    <TextBlock x:Name="Txt_UICN_LawnGreen" Background="LawnGreen" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                    <TextBlock x:Name="Txt_UICN_YellowGreen" Background="YellowGreen" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                    <TextBlock x:Name="Txt_UICN_Green" Background="Green" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0">
                    <Label x:Name="Label_Nom_Animal" Content="Nom animal" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="70" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White" FontFamily="Segoe UI Black"/>
                    <Label x:Name="Label_Nom_Scientifique_Animal" Content="Nom Scientifique" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="30" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White" FontFamily="Arial" FontStyle="Italic"/>
                </StackPanel>

                <StackPanel Width="600" Height="150" Margin="0,230,100,0" VerticalAlignment="Top">
                    <Border Background="White" Margin="0,0,55,0" BorderThickness="3" BorderBrush="Black" Width="255" Height="130" CornerRadius="120">
                        <TextBlock x:Name="Text_Info_Pratique" Text="Chat" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Foreground="#FF2C2E87" TextAlignment="Center" Width="200" FontFamily="Segoe UI Black"/>
                    </Border>
                    <Polygon Points="60,0 80,20 30,0" HorizontalAlignment="Center" Margin="0,0,60,0" Fill="white" Stroke="Black" StrokeThickness="3"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Deuxième image avec masque -->
                    <Image x:Name="Img_Animal_1"
                   Width="441"  
                   Margin="0,0,0,-60" 
                   Height="368" 
                   Stretch="Fill">
                        <Image.OpacityMask>
                            <ImageBrush ImageSource="RESSOURCES/rond.png" Stretch="Uniform" TileMode="None" />
                        </Image.OpacityMask>
                    </Image>
                </StackPanel>

                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,60,30,0" Width="500">
                    <Image x:Name="Img_Animal_2" Margin="0,0,100,0" d:Source="RESSOURCES/axolotl.jpeg" Height="300" Width="400" Stretch="Fill">
                        <Image.OpacityMask>
                            <ImageBrush ImageSource="RESSOURCES/rond.png" Stretch="Fill"/>
                        </Image.OpacityMask>
                    </Image>
                    <Grid Width="300" Height="313" Margin="0,80,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="53*"/>
                            <ColumnDefinition Width="247*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Image en arrière-plan -->


                        <!-- Labels superposés -->
                        <StackPanel HorizontalAlignment="Right" Orientation="Vertical" Margin="0,-40,-50,-47" Grid.ColumnSpan="2" Width="350">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="RESSOURCES/3.png" Stretch="Fill" Height="80"/>
                                <Border BorderBrush="Black" BorderThickness="2" CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                    <TextBlock x:Name="Label_Habitat" TextAlignment="Center" Text="Habitat" Foreground="Black" FontSize="15" VerticalAlignment="Center" TextWrapping="Wrap" Height="55" FontFamily="Segoe UI Black"/>
