<Window xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"  x:Class="IHM_BASE.CLIENT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        FontFamily="Franklin Gothic Medium"
        Title="Musée des Animaux" Height="1080" Width="1920">
    <Grid>
        <Button x:Name="Btn_Admin" Content="Admin" HorizontalAlignment="Right" VerticalAlignment="Top" Click="Btn_Admin_Click" Height="61" Width="88"/>

        <!--============================================================================-->
        
        <!--Grille Parcours -->


        <Grid x:Name="Grid_Parcours" Visibility="Visible" Background="#FF009EE4">
            <Image Margin="0,800,1657,0" Source="RESSOURCES/bas-gauche.png" Stretch="Fill"/>

            <Image Margin="0,0,1587,647" Source="RESSOURCES/haut-gauche.png" Stretch="Fill"/>

            <Image Margin="1529,0,0,647" Source="RESSOURCES/haut-droite.png" Stretch="Fill"/>

            <Image Margin="1595,743,0,0" Source="RESSOURCES/bas-droite.png" Stretch="Fill"/>


            <ItemsControl x:Name="ParcoursList" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Padding="10" Background="#4976ba" CornerRadius="10">
                            <StackPanel>
                                <!-- Image du parcours -->
                                <Border Margin="10" Padding="10" CornerRadius="10">

                                    <Image Source="{Binding imgPathParcours}" Width="100" Height="100" Stretch="UniformToFill" />
                                
                                </Border>
                                <!-- Nom du parcours -->
                                <TextBlock Text="{Binding nomParcours}" FontWeight="Bold" TextAlignment="Center" Margin="5" />

                                <!-- Description -->
                                <TextBlock Text="{Binding descParcours}" FontStyle="Italic" TextAlignment="Center" TextWrapping="Wrap" Margin="5" />

                                <!-- Bouton pour accéder au parcours -->
                                <Border Margin="10" Padding="10" CornerRadius="10">

                                    <Button x:Name="Btn_Open_Parcours" Content="Voir le parcours"
                                        Command="{Binding OpenParcoursCommand}" 
                                        Margin="5,10,5,0" Click="Btn_Open_Parcours_Click" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!--============================================================================-->

        <!--Grille de recherche d'animal-->
        <Grid x:Name="Grid_Recherche" Visibility="Hidden">

            <!-- Grille principale -->
            <Grid Margin="10" VerticalAlignment="Stretch" Visibility="Hidden">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1253*" />
                    <!-- Carte -->
                    <ColumnDefinition Width="647*" />
                    <!-- Résultats -->
                </Grid.ColumnDefinitions>

                <!-- Carte du monde -->
                <Border Grid.Column="0" Background="White" Margin="0,12,272,-12" Grid.ColumnSpan="2">
                    <Grid Margin="0,-56,0,0">
                        <!-- Carte du monde -->
                        <Image Source="RESSOURCES/monde.png" Stretch="Fill" />
                        <!-- Zones cliquables -->
                        <Canvas>
                            <!-- AMERIQUE DU NORD -->
                            <Button Canvas.Left="10" Canvas.Top="40" Width="660" Height="601" Background="Transparent" BorderBrush="Transparent" 
                    Click="Zone_Click_Amerique_Nord" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0"/>

                            <!-- AMERIQUE DU SUD -->
                            <Button Canvas.Left="388" Canvas.Top="618" Width="220" Height="403" Background="Transparent" BorderBrush="Transparent"
                                    Click="Zone_Click_Amerique_Sud" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0">
                            </Button>

                            <!-- AFRIQUE -->
                            <Button Canvas.Left="686" Canvas.Top="479" Width="240" Height="443" Background="Transparent" BorderBrush="Transparent"
                                Click="Zone_Click_Afrique" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0">
                            </Button>
                            <Button Canvas.Left="931" Canvas.Top="637" Width="139" Height="265" Background="Transparent" BorderBrush="Transparent"
                                Click="Zone_Click_Afrique" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0">
                            </Button>

                            <!-- Europe -->
                            <Button Canvas.Left="675" Width="256" Height="387" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Europe" HorizontalAlignment="Left" VerticalAlignment="Center" Content="@" Canvas.Top="92" Opacity="0"/>
                            <Button Canvas.Left="936" Width="98" Height="336" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Europe" HorizontalAlignment="Center" VerticalAlignment="Top" Content="@" Canvas.Top="67" Opacity="0"/>

                            <!-- Asie -->
                            <Button Canvas.Left="1039" Canvas.Top="67" Width="589" Height="616" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Asie" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0">
                            </Button>
                            <Button Canvas.Left="931" Canvas.Top="408" Width="103" Height="200" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Asie" HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0">
                            </Button>

                            <!-- Oceanie -->
                            <Button Canvas.Left="1274" Canvas.Top="688" Width="312" Height="264" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Oceanie" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0">
                            </Button>

                            <!-- Antartique -->
                            <Button Canvas.Left="470" Canvas.Top="1001" Width="972" Height="100" Background="Transparent" BorderBrush="Transparent" Click="Zone_Click_Antartique" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0">
                            </Button>
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Width="250" Visibility="Hidden">
                <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Width="250" Height="30"/>
                <ListBox x:Name="Lstbx_Animaux" MouseDoubleClick="Lstbx_Animaux_MouseDoubleClick" Width="250" Height="1050">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="Img_Animal_1" Width="60" Source="RESSOURCES/axolotl.jpeg" Margin="2" Height="60" Stretch="Fill">
                                    <Image.OpacityMask>
                                        <ImageBrush ImageSource="RESSOURCES/rond.png" Stretch="Uniform" TileMode="None" />
                                    </Image.OpacityMask>
                                </Image>
                                <Border Height="70" Width="150" Background="White" HorizontalAlignment="Right" CornerRadius="10" Margin="2">
                                    <TextBlock Text="{Binding nomCommun}" VerticalAlignment="Center" Margin="5" HorizontalAlignment="Center" FontSize="16" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

        </Grid>

        <!--============================================================================-->

        <!--Grille d'affichage de l'animal recherché-->
        <Grid x:Name="Grid_Info" Visibility="Hidden" d:Visibility="Hidden" Background="#FF009EE4">

            <Image Margin="-71,382,1199,-50" Source="RESSOURCES/rond-blanc.png" Stretch="Fill"/>

            <Image Margin="0,800,1657,0" Source="RESSOURCES/bas-gauche.png" Stretch="Fill"/>

            <Image Margin="0,0,1587,647" Source="RESSOURCES/haut-gauche.png" Stretch="Fill"/>

            <Image Margin="726,330,730,269" Source="RESSOURCES/rond.png" Stretch="Fill"/>

            <Image Margin="1529,0,0,647" Source="RESSOURCES/haut-droite.png" Stretch="Fill"/>

            <Button x:Name="Button_Close" Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Height="60" Width="60" Background="Red" FontSize="30" Click="Button_Close_Click"/>

            <StackPanel Margin="300,150,0,0" Width="400" Height="200" VerticalAlignment="Top" HorizontalAlignment="Left">
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0">
                    <Border Margin="0,0,0,8" CornerRadius="10" Background="#dd8e0b" Width="350" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Label x:Name="Label_Famille" Content="Embranchement" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    </Border>
                    <Border Margin="0,0,0,8" CornerRadius="10" Background="#d3dd0b" Width="295" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Label x:Name="Label_Ordre" Content="Classe" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    </Border>
                    <Border Margin="0,0,0,8" CornerRadius="10" Background="#94dd0b" Width="240" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Label x:Name="Label_Classe" Content="Ordre" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    </Border>
                    <Border Margin="0,0,0,8" CornerRadius="10" Background="#32dd0b " Width="185" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Label x:Name="Label_Embranchement" Content="Famille" HorizontalContentAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="70,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="Tbx_Description_Global" TextAlignment="Left" Margin="25,0,20,0" HorizontalAlignment="Left" TextWrapping="Wrap" Height="440" Width="225" Text="TextBlock" VerticalAlignment="Bottom"  FontSize="15" Foreground="#FF2C2E87"/>
                    <TextBlock x:Name="Tbx_Description_Global1" TextAlignment="Left" Margin="0,0,0,0" HorizontalAlignment="Left" TextWrapping="Wrap" Height="440" Width="225" Text="TextBlock" VerticalAlignment="Bottom"  FontSize="15" Foreground="#FF2C2E87"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="Text_UICN" TextAlignment="Center" HorizontalAlignment="Right" TextWrapping="Wrap" Text="TextBlock" Height="160" Width="300" VerticalAlignment="Top" Foreground="#FFCE1619" Margin="160,10,0,0" FontSize="15"/>

                    <Border Background="White" Margin="145,0,0,0" CornerRadius="20" Height="103">
                        <StackPanel Orientation="Vertical" Margin="15,0,15,0">
                            <TextBlock x:Name="Text_Critere_Menace" TextAlignment="Center" Margin="0,10,0,20" TextWrapping="Wrap" Text="TextBlock" Height="40" Width="200" FontSize="20" FontWeight="Bold" Foreground="#FF2C2E87"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="Txt_UICN_Black" Background="BLack" Text="" Width="20" Height="10" FontSize="15" />
                                <TextBlock x:Name="Txt_UICN_Red" Background="Red" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                <TextBlock x:Name="Txt_UICN_Orange" Background="Orange" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                <TextBlock x:Name="Txt_UICN_Yellow" Background="#feed00" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                <TextBlock x:Name="Txt_UICN_LawnGreen" Background="LawnGreen" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                <TextBlock x:Name="Txt_UICN_YellowGreen" Background="YellowGreen" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                                <TextBlock x:Name="Txt_UICN_Green" Background="Green" Margin="8,0,0,0" Text="" Width="20" Height="10" FontSize="15" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0">
                <Label x:Name="Label_Nom_Animal" Content="Nom animal" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="70" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White"/>
                <Label x:Name="Label_Nom_Scientifique_Animal" Content="Nom Scientifique" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="30" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White" />
            </StackPanel>

            <StackPanel Width="600" Height="150" Margin="0,230,100,0" VerticalAlignment="Top">
                <Border Background="White" Margin="0,0,55,0" Width="250" Height="130" CornerRadius="120">
                    <TextBlock x:Name="Text_Info_Pratique" Text="Chat" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="13" FontWeight="Bold" Foreground="#FF2C2E87" TextAlignment="Center" Width="200"/>
                </Border>
                <Polygon Points="60,0 80,20 30,0" HorizontalAlignment="Center" Margin="0,0,60,0" Fill="white" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Deuxième image avec masque -->
                <Image x:Name="Img_Animal_1"
                   Width="441" 
                   Source="RESSOURCES/axolotl.jpeg" 
                   Margin="0,0,0,-60" 
                   Height="368" 
                   Stretch="Fill">
                    <Image.OpacityMask>
                        <ImageBrush ImageSource="RESSOURCES/rond.png" Stretch="Uniform" TileMode="None" />
                    </Image.OpacityMask>
                </Image>
            </StackPanel>

            <Image Source="RESSOURCES/world.png" Margin="845,800,577,25" RenderTransformOrigin="-6.134,0.197" />
            <Label x:Name="Label_Localisation" Content="Pays" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Top" HorizontalAlignment="Left" Background="{x:Null}" Margin="1056,1013,0,0" Width="193" FontSize="20" Height="38" Foreground="White"/>

            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,100,100,0">
                <Image x:Name="Img_Animal_2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="400" Source="RESSOURCES/axolotl.jpeg">
                    <Image.OpacityMask>
                        <ImageBrush ImageSource="RESSOURCES/rond.png" Stretch="Fill"/>
                    </Image.OpacityMask>
                </Image>
                <Grid Width="300" Height="313" Margin="0,80,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="53*"/>
                        <ColumnDefinition Width="247*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Image en arrière-plan -->


                    <!-- Labels superposés -->
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Orientation="Vertical" Margin="-40,-40,0,0" Grid.ColumnSpan="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="RESSOURCES/3.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <TextBlock x:Name="Label_Habitat" TextAlignment="Center" Text="Habitat" Foreground="Black" FontSize="20" VerticalAlignment="Center" TextWrapping="Wrap" Height="55" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image  Source="RESSOURCES/1.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <Label x:Name="Label_Taille" Content="Taille" Foreground="Black" FontSize="20" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image Source="RESSOURCES/4.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <Label x:Name="Label_Poids" Content="Poids" Foreground="Black" FontSize="20" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image Source="RESSOURCES/5.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <Label x:Name="Label_Duree_Vie" Content="Durée de vie" Foreground="Black" FontSize="20" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Image x:Name="Img_Animal_3" Width="324" Source="RESSOURCES/axolotl.jpeg" Height="232">
                    <Image.OpacityMask>
                        <ImageBrush ImageSource="RESSOURCES/rond.png" Stretch="Uniform" TileMode="None"/>
                    </Image.OpacityMask>
                </Image>
            </StackPanel>
            <Image Margin="1595,743,0,0" Source="RESSOURCES/bas-droite.png" Stretch="Fill"/>
        </Grid>
    </Grid>
</Window>