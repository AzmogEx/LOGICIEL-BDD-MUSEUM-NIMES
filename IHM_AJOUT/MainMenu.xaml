<Window x:Class="IHM_BASE.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="Menu" Height="600" Width="1000"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Button x:Name="BTN_ADD" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16" Content="Ajouter une espèce" Padding="10" Click="BTN_ADD_Click" Margin="205,439,0,0"/>
        <Button x:Name="BTN_EDIT" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16" Content="Modifier l'espèce sélectionnée" Padding="10" Margin="205,493,0,0" Click="BTN_EDIT_Click"/>
        <Button x:Name="BTN_REFRESH" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16" Content="Refresh" Padding="10" Margin="209,10,0,0" Click="BTN_REFRESH_Click"/>
        <ListBox Width="200" HorizontalAlignment="Left" x:Name="LB_Especes" SelectionChanged="LB_Especes_SelectionChanged"/>
    </Grid>
</Window>
