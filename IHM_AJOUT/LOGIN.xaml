<Window x:Class="IHM_BASE.LOGIN"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="LOGIN" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="400" Width="650">
            <Label x:Name="Label_Titre" Content="Identifiant de connexion:" HorizontalAlignment="Center" VerticalAlignment="Top" Height="79" Width="548" FontSize="48"/>
            <Label x:Name="Label_User" Content="Utilisateur:" HorizontalAlignment="Left" Margin="30, 90,0,0" VerticalAlignment="Bottom" Height="48" Width="123" FontSize="20"/>
            <Label x:Name="Label_Password" Content="Mots de passe:" HorizontalAlignment="Left" Margin="10,40,0,0" VerticalAlignment="Bottom" Height="48" Width="147" FontSize="20"/>

        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="250">
            <TextBox x:Name="Tbx_User" HorizontalAlignment="Center" Margin="20" TextWrapping="Wrap" VerticalAlignment="Center" Width="320" Height="48" FontSize="26"/>
            <PasswordBox Height="48" x:Name="Tbx_Password" Margin="20" VerticalAlignment="Top" Background="White" FontSize="26"/>
            <Button x:Name="Button_Connect" Content="Se connecter:" HorizontalAlignment="Center" VerticalAlignment="Top" Height="50" Width="130" FontSize="20" Click="Button_Connect_Click"/>
        </StackPanel>
        

    </Grid>
</Window>
