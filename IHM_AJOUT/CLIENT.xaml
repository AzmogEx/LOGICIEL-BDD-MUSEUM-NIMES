<Window x:Class="IHM_BASE.CLIENT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="Musée des Animaux" Height="600" Width="1000">
    <Grid>
        <!--Grille de recherche d'animal-->
        <Grid x:Name="Grid_Recherche" Visibility="Hidden">

            <!-- Barre de recherche -->
            <DockPanel DockPanel.Dock="Top" Margin="10" VerticalAlignment="Top">
                <TextBox x:Name="SearchBox" Width="400" Height="30" Margin="5" 
     HorizontalAlignment="Left" VerticalAlignment="Center" />
                <Button x:Name="SearchButton" Content="Rechercher" Width="100" Height="30" 
    Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Grille principale -->
            <Grid Margin="10" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <!-- Carte -->
                    <ColumnDefinition Width="2*" />
                    <!-- Résultats -->
                </Grid.ColumnDefinitions>

                <!-- Carte interactive -->
                <Border Grid.Column="0" Background="#EFEFEF" Margin="5,48,5,5">

                </Border>

                <!-- Résultats -->
                <Border Grid.Column="1" Background="#F5F5F5" Margin="5">
                    <ListView x:Name="ResultsList" Margin="5" VerticalAlignment="Stretch">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Nom" DisplayMemberBinding="{Binding Name}" Width="150"/>
                                <GridViewColumn Header="Pays" DisplayMemberBinding="{Binding Country}" Width="100"/>
                                <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="300"/>
                            </GridView>
                        </ListView.View>
                        <StackPanel Height="479" Width="1180"/>
                    </ListView>
                </Border>
            </Grid>
        </Grid>

        <!--Grille d'affichage de l'animal-->
        <Grid x:Name="Grid_Info">
            <TextBlock HorizontalAlignment="Left" Margin="10,227,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="338" Width="228" Background="#FFFFEA00"/>
            <Label x:Name="Label_Titre_Animal" Content="Le titre" HorizontalAlignment="Left" Margin="452,32,0,0" VerticalAlignment="Top" Width="192" Height="46" FontSize="30" FontWeight="Bold" HorizontalContentAlignment="Center"/>
            <Label x:Name="Label_Titre_Scientifique_Animal" Content="Scientifique" HorizontalAlignment="Left" Margin="452,84,0,0" VerticalAlignment="Top" Width="192" Height="48" FontSize="30" FontWeight="Bold" HorizontalContentAlignment="Center"/>
            <Image x:Name="Img_Animal_1" HorizontalAlignment="Left" Height="126" Margin="190,21,0,0" VerticalAlignment="Top" Width="192" Source="/Capture d’écran 2025-01-20 à 11.01.50.png"/>
            <Image x:Name="Img_Animal_2" HorizontalAlignment="Left" Height="121" Margin="481,333,0,0" VerticalAlignment="Top" Width="192" Source="/Capture d’écran 2025-01-20 à 11.01.50.png"/>
            <Image x:Name="Img_Animal_3" HorizontalAlignment="Left" Height="127" Margin="716,84,0,0" VerticalAlignment="Top" Width="192" Source="/Capture d’écran 2025-01-20 à 11.01.50.png"/>
            <TextBlock HorizontalAlignment="Left" Margin="40,33,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="89" Width="104" Foreground="Black" Background="#FFFFEA00"/>
            <Label x:Name="Label_Localisation" Content="Pays" HorizontalAlignment="Left" Margin="788,328,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FF1300FF"/>
            <Label x:Name="Label_Embranchement" Content="Embranchement" HorizontalAlignment="Left" Margin="262,393,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FF08FF00"/>
            <Label x:Name="Label_Classe" Content="Classe" HorizontalAlignment="Left" Margin="262,333,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FF1FFF00"/>
            <Label x:Name="Label_Ordre" Content="Ordre" HorizontalAlignment="Left" Margin="262,0,0,0" VerticalAlignment="Center" Height="32" Width="120" Background="#FF02FF00"/>
            <Label x:Name="Label_Famille" Content="Famille" HorizontalAlignment="Left" Margin="262,209,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FF00FF15"/>
            <Label x:Name="Label_Habitat" Content="Habitat" HorizontalAlignment="Left" Margin="788,400,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FFE600FF"/>
            <Label x:Name="Label_Taille" Content="Taille" HorizontalAlignment="Left" Margin="788,437,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FFE600FF"/>
            <Label x:Name="Label_Poids" Content="Poids" HorizontalAlignment="Left" Margin="788,474,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FFFF00EA"/>
            <Label x:Name="Label_Duree_Vie" Content="Duree de vie" HorizontalAlignment="Left" Margin="788,511,0,0" VerticalAlignment="Top" Height="32" Width="120" Background="#FFFF00FB"/>
            <TextBlock x:Name="Text_description_Menace" HorizontalAlignment="Left" Margin="404,490,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="76" Width="96" Background="Red"/>
            <TextBlock x:Name="Text_Critere_Menace" HorizontalAlignment="Left" Margin="557,490,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="76" Width="96" Background="Red"/>
            <Button x:Name="Button_Close" Content="X" HorizontalAlignment="Left" Margin="943,10,0,0" VerticalAlignment="Top" Height="67" Width="47" Background="Red" FontSize="50"/>
        </Grid>
    </Grid>
</Window>