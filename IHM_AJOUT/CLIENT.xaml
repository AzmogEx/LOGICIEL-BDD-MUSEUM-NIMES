<Window x:Class="IHM_BASE.CLIENT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        FontFamily="Franklin Gothic Medium"
        Title="Musée des Animaux" Height="1080" Width="1920">
    <Grid>


        <!--Grille de recherche d'animal-->
        <Grid x:Name="Grid_Recherche" Visibility="Visible">



            <!-- Grille principale -->
            <Grid Margin="10" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1253*" />
                    <!-- Carte -->
                    <ColumnDefinition Width="647*" />
                    <!-- Résultats -->
                </Grid.ColumnDefinitions>

                <!-- Carte du monde -->
                <Border Grid.Column="0" Background="#EFEFEF" Margin="0,0,272,5" Grid.ColumnSpan="2">
                    <Grid Margin="0,-56,0,0">
                        <!-- Carte du monde -->
                        <Image Source="/monde.png" Stretch="Fill" />
                        <!-- Zones cliquables -->
                        <Canvas>
                            <!-- AMERIQUE DU NORD -->
                            <Button Canvas.Left="10" Canvas.Top="40" Width="660" Height="523" Background="Transparent" BorderBrush="Transparent" 
                    Click="Zone_Click_Amerique_Nord" HorizontalAlignment="Left" VerticalAlignment="Center">
                            </Button>

                            <!-- AMERIQUE DU SUD -->
                            <Button Canvas.Left="388" Canvas.Top="618" Width="220" Height="403" Background="Transparent" BorderBrush="Transparent"
                                    Click="Zone_Click_Amerique_Sud" HorizontalAlignment="Left" VerticalAlignment="Top">
                            </Button>

                            <!-- AFRIQUE -->
                            <Button Canvas.Left="686" Canvas.Top="479" Width="240" Height="403" Background="Transparent" BorderBrush="Transparent"
                            Click="Zone_Click_Afrique" HorizontalAlignment="Left" VerticalAlignment="Center">
                            </Button>

                            <!-- Europe -->
                            <Button Canvas.Left="686" Width="326" Height="387" Background="Transparent" BorderBrush="Transparent"
Click="Zone_Click_Europe" HorizontalAlignment="Left" VerticalAlignment="Center" Content="@" Canvas.Top="92"/>

                            <!-- Asie -->
                            <Button Canvas.Left="1012" Canvas.Top="67" Width="616" Height="541" Background="Transparent" BorderBrush="Transparent"
Click="Zone_Click_Asie" HorizontalAlignment="Left" VerticalAlignment="Center">
                            </Button>

                            <!-- Oceanie -->
                            <Button Canvas.Left="1274" Canvas.Top="688" Width="312" Height="264" Background="Transparent" BorderBrush="Transparent"
Click="Zone_Click_Oceanie" HorizontalAlignment="Left" VerticalAlignment="Top">
                            </Button>

                            <!-- Antartique -->
                            <Button Canvas.Left="470" Canvas.Top="1001" Width="972" Height="100" Background="Transparent" BorderBrush="Transparent"
Click="Zone_Click_Antartique" HorizontalAlignment="Left" VerticalAlignment="Top">
                            </Button>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- Résultats -->
                <Border Grid.Column="1" Background="#F5F5F5" Margin="380,5,5,5">
                    <ListBox x:Name="Lstbx_Animaux" MouseDoubleClick="Lstbx_Animaux_MouseDoubleClick" Margin="10,70,0,122"/>
                </Border>
                <TextBox x:Name="SearchBox" Margin="380,10,10,992" Grid.Column="1" TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Grid>

        <!--============================================================================-->

        <!--Grille d'affichage de l'animal recherché-->
        <Grid x:Name="Grid_Info" Visibility="Hidden" Background="#FF009EE4">

            <Image Margin="-71,392,1221,-50" Source="/rond-blanc.png" Stretch="Fill"/>

            <Image Margin="0,800,1657,0" Source="/bas-gauche.png" Stretch="Fill"/>

            <Image Margin="0,0,1587,647" Source="/haut-gauche.png" Stretch="Fill"/>

            <Image Margin="726,330,730,269" Source="/rond.png" Stretch="Fill"/>

            <Image Margin="1529,0,0,647" Source="/haut-droite.png" Stretch="Fill"/>

            <Button x:Name="Button_Close" Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Height="60" Width="60" Background="Red" FontSize="30" Click="Button_Close_Click"/>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="70,0,0,0">
                <StackPanel Margin="40,0,0,100">
                    <Grid Margin="20" Width="300">
                        <Image Source="/arbre.png" Stretch="Fill" Height="250" Width="300"/>

                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,-5">
                            <Label x:Name="Label_Famille" Margin="0,0,0,3"   Content="Famille"  Width="150" Background="{x:Null}" Foreground="#FF2C2E87" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                            <Label x:Name="Label_Ordre" Margin="0,0,0,5"   Content="Ordre" Width="150" Background="{x:Null}" Foreground="#FF2C2E87" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                            <Label x:Name="Label_Classe" Margin="0,0,0,5"   Content="Classe" Width="150" Background="{x:Null}" Foreground="#FF2C2E87" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                            <Label x:Name="Label_Embranchement" Margin="0,0,0,7"   Content="Embranchement" Width="150" Background="{x:Null}" Foreground="#FF2C2E87" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="Tbx_Description_Global" TextAlignment="Left" Margin="10,0,20,0" HorizontalAlignment="Left" TextWrapping="Wrap" Height="440" Width="225" Text="TextBlock" VerticalAlignment="Bottom"  FontSize="15" Foreground="#FF2C2E87"/>
                    <TextBlock x:Name="Tbx_Description_Global1" TextAlignment="Left" Margin="0,0,0,0" HorizontalAlignment="Left" TextWrapping="Wrap" Height="440" Width="225" Text="TextBlock" VerticalAlignment="Bottom"  FontSize="15" Foreground="#FF2C2E87"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="Text_UICN" TextAlignment="Center" HorizontalAlignment="Right" TextWrapping="Wrap" Text="TextBlock" Height="160" Width="300" VerticalAlignment="Top" Foreground="#FFCE1619" Margin="160,10,0,0" FontSize="15"/>
                    <Image Source="/critere.png" Margin="10,0,0,0" Stretch="Fill" Height="148" Width="148"/>
                    <TextBlock x:Name="Text_Critere_Menace" TextAlignment="Center" Margin="-150,0,0,-70" TextWrapping="Wrap" Text="TextBlock" Height="38" Width="101" FontSize="13" FontWeight="Bold" FontFamily="Trebuchet MS" Foreground="White"/>
                </StackPanel>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0">
                <Label x:Name="Label_Nom_Animal" Content="Nom animal" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="70" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White"/>
                <Label x:Name="Label_Nom_Scientifique_Animal" Content="Nom Scientifique" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="30" FontWeight="Bold" HorizontalContentAlignment="Center" Foreground="White" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Superposition avec Grid -->
                <Grid Width="250" Height="150">
                    <!-- Image en arrière-plan -->
                    <Image Source="/chat.png" Stretch="Fill" Margin="-50,-19,0,0" />

                    <TextBlock x:Name="Text_Info_Pratique" Text="Chat" 
                   HorizontalAlignment="Left" 
                   VerticalAlignment="Top" TextWrapping="Wrap"
                   FontSize="13" 
                   FontWeight="Bold" 
                   Foreground="#FF2C2E87" 
                   Margin="10,12,0,0"
                   TextAlignment="Center" Width="187" Height="69"/>
                </Grid>

                <!-- Deuxième image avec masque -->
                <Image x:Name="Img_Animal_1"
           Width="441" 
           Source="/axolotl.jpeg" 
           Margin="0,0,0,85" 
           Height="368" 
           Stretch="Fill">
                    <Image.OpacityMask>
                        <ImageBrush ImageSource="/rond.png" Stretch="Uniform" TileMode="None" />
                    </Image.OpacityMask>
                </Image>
            </StackPanel>

            <Image Source="/carte.png" Margin="845,800,577,25" RenderTransformOrigin="-6.134,0.197" />
            <Label x:Name="Label_Localisation" Content="Pays" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Top" HorizontalAlignment="Left" Background="{x:Null}" Margin="1056,1013,0,0" Width="193" FontSize="20" Height="38" Foreground="White"/>

            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,100,100,0">
                <Image x:Name="Img_Animal_2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="400" Source="/axolotl.jpeg">
                    <Image.OpacityMask>
                        <ImageBrush ImageSource="/rond.png" Stretch="Fill"/>
                    </Image.OpacityMask>
                </Image>
                <Grid Width="300" Height="313" Margin="0,80,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="53*"/>
                        <ColumnDefinition Width="247*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Image en arrière-plan -->


                    <!-- Labels superposés -->
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Orientation="Vertical" Margin="-40,-40,0,0" Grid.ColumnSpan="2">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/3.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <TextBlock x:Name="Label_Habitat" TextAlignment="Center" Text="Habitat" Foreground="Black" FontSize="20" VerticalAlignment="Center" TextWrapping="Wrap" Height="55" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image  Source="/1.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <Label x:Name="Label_Taille" Content="Taille" Foreground="Black" FontSize="20" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/4.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <Label x:Name="Label_Poids" Content="Poids" Foreground="Black" FontSize="20" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/5.png" Stretch="Fill" Height="80"/>
                            <Border CornerRadius="10" Background="White" Margin="20,0,0,0" Width="170" Height="55">
                                <Label x:Name="Label_Duree_Vie" Content="Durée de vie" Foreground="Black" FontSize="20" HorizontalContentAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Image x:Name="Img_Animal_3" Width="324" Source="/axolotl.jpeg" Height="232">
                    <Image.OpacityMask>
                        <ImageBrush ImageSource="/rond.png" Stretch="Uniform" TileMode="None"/>
                    </Image.OpacityMask>
                </Image>
            </StackPanel>
            <Image Margin="1595,743,0,0" Source="/bas-droite.png" Stretch="Fill"/>
        </Grid>
    </Grid>
</Window>