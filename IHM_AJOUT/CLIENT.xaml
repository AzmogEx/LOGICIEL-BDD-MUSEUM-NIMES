<Window x:Class="IHM_BASE.CLIENT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IHM_BASE"
        mc:Ignorable="d"
        Title="Musée des Animaux" Height="600" Width="1000">
    <Grid>
        
        <!--Grille de recherche d'animal-->
        <Grid x:Name="Grid_Recherche" Visibility="Hidden">

            <!-- Barre de recherche -->
            <DockPanel DockPanel.Dock="Top" Margin="10" VerticalAlignment="Top">
                <TextBox x:Name="SearchBox" Width="400" Height="30" Margin="5" 
     HorizontalAlignment="Left" VerticalAlignment="Center" TextChanged="SearchBox_TextChanged" />
                
            </DockPanel>

            <!-- Grille principale -->
            <Grid Margin="10" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <!-- Carte -->
                    <ColumnDefinition Width="2*" />
                    <!-- Résultats -->
                </Grid.ColumnDefinitions>

                <!-- Carte du monde -->
                <Border Grid.Column="0" Background="#EFEFEF" Margin="5,48,5,5">

                </Border>

                <!-- Résultats -->
                <Border Grid.Column="1" Background="#F5F5F5" Margin="5">
                    <ListBox x:Name="Lstbx_Animaux" MouseDoubleClick="Lstbx_Animaux_MouseDoubleClick"/>
                </Border>
            </Grid>
        </Grid>
        
        <!--============================================================================-->
            
        <!--Grille d'affichage de l'animal recherché-->
        <Grid x:Name="Grid_Info">
            
            <!--Label Titre--><!--
            <Label x:Name="Label_Titre_Animal" Content="Le titre" HorizontalAlignment="Left" VerticalAlignment="Top" Width="192" FontSize="30" FontWeight="Bold" HorizontalContentAlignment="Center"/>
            <Label x:Name="Label_Titre_Scientifique_Animal" Content="Scientifique" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Center"/>
            
            --><!--Image--><!--
            <Image x:Name="Img_Animal_1" HorizontalAlignment="Left" VerticalAlignment="Top" Source="/Capture d’écran 2025-01-20 à 11.01.50.png"/>
            <Image x:Name="Img_Animal_2" HorizontalAlignment="Left" VerticalAlignment="Top" Source="/Capture d’écran 2025-01-20 à 11.01.50.png"/>
            <Image x:Name="Img_Animal_3" HorizontalAlignment="Left" VerticalAlignment="Top" Source="/Capture d’écran 2025-01-20 à 11.01.50.png"/>

            --><!--Description--><!--
            <TextBlock x:Name="Tbx_Description_Global" HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Background="#FFFFEA00"/>
            <TextBlock x:Name="Text_Info_Pratique" HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Foreground="Black" Background="#FFFFEA00"/>
            <TextBlock x:Name="Text_UICN" HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Background="Red"/>
            <TextBlock x:Name="Text_Critere_Menace" HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Background="Red"/>
            
            --><!--Label Information--><!--
            <Label x:Name="Label_Localisation" Content="Pays" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FF1300FF"/>
            <Label x:Name="Label_Embranchement" Content="Embranchement" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FF08FF00"/>
            <Label x:Name="Label_Classe" Content="Classe" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FF1FFF00"/>
            <Label x:Name="Label_Ordre" Content="Ordre" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#FF02FF00"/>
            <Label x:Name="Label_Famille" Content="Famille" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FF00FF15"/>
            <Label x:Name="Label_Habitat" Content="Habitat" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFE600FF"/>
            <Label x:Name="Label_Taille" Content="Taille" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFE600FF"/>
            <Label x:Name="Label_Poids" Content="Poids" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFFF00EA"/>
            <Label x:Name="Label_Duree_Vie" Content="Duree de vie" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#FFFF00FB"/>
            
            --><!--Button close--><!--
            <Button x:Name="Button_Close" Content="X" HorizontalAlignment="Left" Margin="943,10,0,0" VerticalAlignment="Top" Height="67" Width="47" Background="Red" FontSize="50" Click="Button_Close_Click"/>-->
            
        </Grid>
    </Grid>
</Window>